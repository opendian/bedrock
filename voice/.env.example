# Copy to .env (gitignored). No API key needed — backends use existing CLI auth or run local.

# LLM backend: claude (default) | codex | local
# BEDROCK_LLM_BACKEND=claude
# BEDROCK_CLAUDE_MODEL=        # blank = claude CLI default
# BEDROCK_CODEX_MODEL=         # blank = codex CLI default

# Local backend only (BEDROCK_LLM_BACKEND=local):
# BEDROCK_LLM_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit
# BEDROCK_LLM_MAX_TOKENS=1200

# Speech models / voice:
# BEDROCK_WHISPER=mlx-community/whisper-large-v3-turbo
# BEDROCK_KOKORO_LANG=a            # a=US English, b=UK, f=French, e=Spanish, i=Italian, p=Portuguese
# BEDROCK_KOKORO_VOICE=af_heart
# BEDROCK_HOTKEY=<ctrl>+<alt>+d
