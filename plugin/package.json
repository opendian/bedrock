{
  "name": "bedrock-voice",
  "version": "0.1.0",
  "description": "Accessibility-first read-aloud Obsidian plugin with local Kokoro TTS and real-time karaoke captions.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "accessibility",
    "dyslexia",
    "adhd",
    "neurodivergent",
    "tts",
    "kokoro",
    "read-aloud",
    "karaoke-captions"
  ],
  "author": "Yani Meziani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanimeziani/bedrock-voice.git"
  },
  "homepage": "https://github.com/yanimeziani/bedrock-voice#readme",
  "bugs": {
    "url": "https://github.com/yanimeziani/bedrock-voice/issues"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "^1.5.7",
    "typescript": "^5.4.5"
  }
}
